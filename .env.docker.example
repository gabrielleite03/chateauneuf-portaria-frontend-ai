# Images publicadas no DockerHub.
# Use tag fixa para garantir que a estacao instalou exatamente a versao esperada.
FRONTEND_IMAGE=gabrielleite03/chateauneuf-portaria-frontend:2026.07.15.3
BACKEND_IMAGE=gabrielleite03/chateauneuf-portaria-backend:2026.07.14.4
FRONTEND_APP_VERSION=2026.07.15.3
BACKEND_APP_VERSION=2026.07.14.4

# Portas expostas na estacao.
FRONTEND_PORT=8081
FRONTEND_HTTPS_PORT=8443
BACKEND_PORT=18080

# Google Sheets.
GOOGLE_SHEET_ID=10AqRHD9k925C51msbKEzOiXkCTKtzW9A4mi1nNqpoG8
GOOGLE_SHEET_NAME=Entradas
GOOGLE_DRIVE_FOLDER_ID=
SYNC_INTERVAL_SECONDS=30

# Pasta local para o banco SQLite usado pelo backend Docker.
LOCAL_DATA_DIR=./data

# Pasta local sincronizada pelo Google Drive para computador.
# Exemplo Windows: C:\Users\AdminUser\Google Drive\Meu Drive\Fotos Portaria
LOCAL_PHOTO_DIR=./photos

# Certificados locais usados pelo frontend HTTPS.
LOCAL_CERT_DIR=./certs

# Origem permitida para chamadas diretas ao backend.
ALLOWED_ORIGIN=http://localhost:8081
