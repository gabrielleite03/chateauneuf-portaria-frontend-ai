# Images publicadas no DockerHub.
# A tag latest sempre aponta para a ultima versao publicada.
FRONTEND_IMAGE=gabrielleite03/chateauneuf-portaria-frontend:latest
BACKEND_IMAGE=gabrielleite03/chateauneuf-portaria-backend:latest

# Portas expostas na estacao.
FRONTEND_PORT=8081
BACKEND_PORT=18080

# Google Sheets.
GOOGLE_SHEET_ID=
GOOGLE_SHEET_NAME=Entradas
SYNC_INTERVAL_SECONDS=30

# Origem permitida para chamadas diretas ao backend.
ALLOWED_ORIGIN=http://localhost:8081
